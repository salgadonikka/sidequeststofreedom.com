---
// Update these with your real details
const author = {
  name: 'Side Quests To Freedom',
  bio: 'On a mission to escape the 9-to-5 through side hustles, passive income, and relentless experimentation. Sharing everything I learn along the way.',
  avatar: '/images/avatar.jpg', // add your photo to public/images/
};
---

<div class="author-bio">
  <div class="author-avatar-wrap">
    <img
      src={author.avatar}
      alt={author.name}
      class="author-avatar"
      width="56"
      height="56"
      onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
    />
    <div class="author-avatar-fallback" aria-hidden="true">SQ</div>
  </div>
  <div class="author-info">
    <span class="author-name">{author.name}</span>
    <p class="author-text">{author.bio}</p>
  </div>
</div>

<style>
  .author-bio {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    margin-top: 2.5rem;
    padding: 1.25rem;
    background: rgba(110, 86, 207, 0.05);
    border: 1px solid rgba(110, 86, 207, 0.12);
    border-radius: 10px;
  }

  .author-avatar-wrap {
    flex-shrink: 0;
    position: relative;
  }

  .author-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(110, 86, 207, 0.3);
  }

  .author-avatar-fallback {
    display: none;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(110, 86, 207, 0.2);
    border: 2px solid rgba(110, 86, 207, 0.3);
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 700;
    color: #6E56CF;
  }

  .author-info {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .author-name {
    font-size: 0.85rem;
    font-weight: 700;
    color: #E2E2F0;
  }

  .author-text {
    font-size: 0.82rem;
    color: rgba(226, 226, 240, 0.5);
    line-height: 1.55;
  }
</style>
