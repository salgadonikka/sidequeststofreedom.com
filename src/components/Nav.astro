---
const pathname = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<nav class="site-nav" aria-label="Main navigation">
  <div class="nav-inner">
    <a href="/links" class="nav-brand" aria-label="Side Quests To Freedom — Home">
      <span class="nav-brand-dot" aria-hidden="true"></span>
      <span class="nav-brand-text">SQTF</span>
    </a>

    <ul class="nav-links" role="list">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={['nav-link', { 'nav-link--active': isActive(href) }]}
            aria-current={isActive(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .site-nav {
    position: relative;
    z-index: 10;
    padding: 0 1.5rem;
    border-bottom: 1px solid rgba(110, 86, 207, 0.1);
    background: rgba(6, 6, 16, 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .nav-inner {
    max-width: 1020px;
    margin: 0 auto;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav-brand-dot {
    width: 7px;
    height: 7px;
    background: #6E56CF;
    border-radius: 1px;
    transform: rotate(45deg);
    flex-shrink: 0;
  }

  .nav-brand-text {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: rgba(226, 226, 240, 0.7);
    transition: color 0.2s;
  }

  .nav-brand:hover .nav-brand-text {
    color: #E2E2F0;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
  }

  .nav-link {
    font-size: 0.78rem;
    font-weight: 500;
    color: rgba(226, 226, 240, 0.45);
    text-decoration: none;
    padding: 0.3rem 0.65rem;
    border-radius: 6px;
    transition: color 0.2s, background 0.2s;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: #E2E2F0;
    background: rgba(110, 86, 207, 0.1);
  }

  .nav-link--active {
    color: #6E56CF;
    background: rgba(110, 86, 207, 0.1);
  }

  .nav-link--active:hover {
    color: #6E56CF;
  }

  @media (max-width: 400px) {
    .nav-brand-text {
      display: none;
    }
  }
</style>
