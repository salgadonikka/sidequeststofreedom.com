---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const latestPost = posts[0] ?? null;
---

<BaseLayout
  title="Side Quests To Freedom"
  description="Practical strategies, honest breakdowns, and real income reports for people building financial freedom one side hustle at a time."
  canonicalUrl="https://sidequeststofreedom.com"
>

  <!-- Animated geometric canvas background -->
  <canvas id="geo-canvas" aria-hidden="true"></canvas>

  <!-- Gradient mesh background -->
  <div class="lp-bg" aria-hidden="true"></div>

  <main class="lp-main">

    <!-- ===================== HERO ===================== -->
    <section class="hero" aria-label="Introduction">

      <!-- Left: profile picture -->
      <div class="hero-profile">
        <div class="avatar-wrap avatar-lg">
          <div class="avatar-ring" aria-hidden="true"></div>
          <div class="avatar-inner avatar-inner-lg">
            <!--<img
              src="/images/profilepicture.png"
              alt="Side Quests To Freedom"
              onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
            />-->
            <span class="avatar-placeholder">SQ</span>
          </div>
        </div>
      </div>

      <!-- Right: headline + CTA -->
      <div class="hero-content">
        <span class="hero-eyebrow">
          <span class="eyebrow-dot" aria-hidden="true"></span>
          Side Quests To Freedom
        </span>

        <h1 class="hero-headline">
          Building income stacks. One <br />
          <span class="headline-accent">side quest</span> at a time.
        </h1>

        <p class="hero-desc">For burned-out employees quietly building their escape plan.</p>

        <nav class="hero-nav" aria-label="Primary navigation">
          <a href="/blog" class="btn btn-primary">Read the Blog</a>
          <a href="/links" class="btn btn-secondary">My Links</a>
          <a href="#" class="btn btn-ghost">Newsletter</a>
        </nav>
      </div>

    </section>

    <!-- ===================== LATEST POST ===================== -->
    {latestPost && (
      <section class="latest-section" aria-label="Latest post">
        <div class="section-label">
          <span class="section-dot" aria-hidden="true"></span>
          <span>Latest Post</span>
        </div>

        <a href={`/blog/${latestPost.slug}`} class="latest-card">
          <div class="latest-card-body">
            <h2 class="latest-title">{latestPost.data.title}</h2>
            <p class="latest-excerpt">{latestPost.data.description}</p>
          </div>
          <span class="latest-read-more">
            Read more <span aria-hidden="true">&#8594;</span>
          </span>
        </a>
      </section>
    )}

    <footer class="lp-footer">
      <p>&copy; {new Date().getFullYear()} Side Quests To Freedom</p>
    </footer>

  </main>

</BaseLayout>

<style>
  /* ---- Gradient mesh background ---- */
  .lp-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 70% 60% at 0% 0%,   rgba(110, 86, 207, 0.08) 0%, transparent 70%),
      radial-gradient(ellipse 45% 45% at 100% 100%, rgba(0, 229, 160, 0.08) 0%, transparent 65%),
      #060610;
  }

  /* ---- Canvas ---- */
  #geo-canvas {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  /* ---- Layout ---- */
  .lp-main {
    position: relative;
    z-index: 2;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    max-width: 900px;
    margin: 0 auto;
    padding: 2.5rem 2rem;
    gap: 0;
  }

  /* ---- Hero ---- */
  .hero {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    align-items: center;
    gap: 4rem;
    padding: 1rem 0;
  }

  /* ---- Profile side ---- */
  .hero-profile {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .avatar-lg {
    width: 220px !important;
    height: 220px !important;
  }

  /* Thicker ring */
  .avatar-lg .avatar-ring {
    inset: -5px;
  }

  .avatar-inner-lg {
    width: 220px !important;
    height: 220px !important;
    outline-width: 5px !important;
  }

  .avatar-inner-lg .avatar-placeholder {
    font-size: 5rem;
  }

  /* ---- Content side ---- */
  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    justify-content: center;
    align-self: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(226, 226, 240, 0.4);
  }

  .eyebrow-dot {
    width: 5px;
    height: 5px;
    background: #6E56CF;
    border-radius: 1px;
    transform: rotate(45deg);
    flex-shrink: 0;
  }

  .hero-headline {
    font-size: clamp(1.9rem, 4vw, 2.75rem);
    font-weight: 700;
    color: #E2E2F0;
    letter-spacing: -0.03em;
    line-height: 1.15;
  }

  .headline-accent {
    background: linear-gradient(90deg, #6E56CF 0%, #00E5A0 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-desc {
    font-size: 0.95rem;
    color: rgba(226, 226, 240, 0.55);
    line-height: 1.65;
    max-width: 420px;
  }

  /* ---- Buttons ---- */
  .hero-nav {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    margin-top: 0.5rem;
  }

  .btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 0.85rem 1.4rem;
    border-radius: 10px;
    text-decoration: none;
    border: 1px solid transparent;
    transition: background 0.2s ease, border-color 0.2s ease,
                transform 0.15s ease, box-shadow 0.2s ease;
  }

  .btn::after {
    content: '→';
    font-size: 1rem;
    opacity: 0.5;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .btn:hover::after {
    transform: translateX(3px);
    opacity: 1;
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn-primary {
    background: #6E56CF;
    color: #fff;
    box-shadow: 0 4px 18px rgba(110, 86, 207, 0.35);
  }

  .btn-primary:hover {
    background: #7d67d8;
    box-shadow: 0 6px 24px rgba(110, 86, 207, 0.5);
  }

  .btn-secondary {
    background: rgba(110, 86, 207, 0.1);
    border-color: rgba(110, 86, 207, 0.35);
    color: #E2E2F0;
  }

  .btn-secondary:hover {
    background: rgba(110, 86, 207, 0.18);
    border-color: rgba(110, 86, 207, 0.55);
  }

  .btn-ghost {
    background: transparent;
    border-color: rgba(226, 226, 240, 0.12);
    color: rgba(226, 226, 240, 0.55);
  }

  .btn-ghost:hover {
    border-color: rgba(0, 229, 160, 0.35);
    color: #00E5A0;
  }

  /* ---- Latest Post ---- */
  .latest-section {
    padding-top: 1.25rem;
    margin-top: 1.5rem;
    border-top: 1px solid rgba(226, 226, 240, 0.06);
  }

  .latest-card {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-top: 0.75rem;
    padding: 1rem 1.25rem;
    background: rgba(110, 86, 207, 0.06);
    border: 1px solid rgba(110, 86, 207, 0.14);
    border-radius: 12px;
    text-decoration: none;
    color: #E2E2F0;
    transition: background 0.2s ease, border-color 0.2s ease,
                transform 0.2s ease, box-shadow 0.2s ease;
    position: relative;
  }

  .latest-card::before {
    content: '';
    position: absolute;
    top: -1px;
    left: -1px;
    width: 12px;
    height: 12px;
    border-top: 2px solid #6E56CF;
    border-left: 2px solid #6E56CF;
    border-radius: 2px 0 0 0;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .latest-card::after {
    content: '';
    position: absolute;
    bottom: -1px;
    right: -1px;
    width: 12px;
    height: 12px;
    border-bottom: 2px solid #6E56CF;
    border-right: 2px solid #6E56CF;
    border-radius: 0 0 2px 0;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .latest-card:hover {
    background: rgba(110, 86, 207, 0.12);
    border-color: rgba(110, 86, 207, 0.3);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(110, 86, 207, 0.15);
  }

  .latest-card:hover::before,
  .latest-card:hover::after {
    opacity: 1;
  }

  .latest-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    min-width: 0;
  }

  .latest-title {
    font-size: 1rem;
    font-weight: 600;
    color: #E2E2F0;
    letter-spacing: -0.01em;
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .latest-excerpt {
    font-size: 0.83rem;
    color: rgba(226, 226, 240, 0.45);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .latest-read-more {
    font-size: 0.8rem;
    font-weight: 600;
    color: #6E56CF;
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 0.2s, transform 0.2s;
  }

  .latest-card:hover .latest-read-more {
    color: #00E5A0;
  }

  /* ---- Footer ---- */
  .lp-footer {
    text-align: center;
    margin-top: 0;
    padding-top: 1rem;
    border-top: 1px solid rgba(226, 226, 240, 0.05);
  }

  .lp-footer p {
    font-size: 0.72rem;
    color: rgba(226, 226, 240, 0.2);
  }

  /* ---- Responsive ---- */
  @media (max-width: 640px) {
    .lp-main {
      padding: 2rem 1.25rem;
      gap: 1.25rem;
    }

    .hero {
      grid-template-columns: 1fr;
      gap: 1.75rem;
      text-align: center;
      padding: 1rem 0;
    }

    .latest-card {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .latest-title {
      white-space: normal;
    }
  }

  /* ---- Reduced motion ---- */
  @media (prefers-reduced-motion: reduce) {
    #geo-canvas { display: none; }
    .btn:hover { transform: none; }
    .latest-card:hover { transform: none; }
  }
</style>

<script>
  const canvas = document.getElementById('geo-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  const PURPLE = 'rgba(110, 86, 207, ';
  const GREEN  = 'rgba(0, 229, 160, ';

  function resize() {
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  function rand(min: number, max: number) {
    return Math.random() * (max - min) + min;
  }

  /* ---- Shape classes ---- */
  class Diamond {
    x = 0; y = 0; size = 0; speed = 0;
    opacity = 0; color = PURPLE; rotation = 0; rotSpeed = 0;

    constructor() { this.reset(true); }

    reset(initial = false) {
      this.x        = rand(0, canvas.width);
      this.y        = initial ? rand(-canvas.height, canvas.height) : canvas.height + rand(20, 80);
      this.size     = rand(8, 38);
      this.speed    = rand(0.2, 0.75);
      this.opacity  = rand(0.1, 0.22);
      this.color    = Math.random() > 0.85 ? GREEN : PURPLE;
      this.rotation = rand(0, Math.PI * 2);
      this.rotSpeed = (Math.random() - 0.5) * 0.004;
    }

    update() {
      this.y        -= this.speed;
      this.rotation += this.rotSpeed;
      if (this.y < -this.size * 2) this.reset();
    }

    draw() {
      ctx.save();
      ctx.translate(this.x, this.y);
      ctx.rotate(this.rotation + Math.PI / 4);
      ctx.strokeStyle = this.color + this.opacity + ')';
      ctx.lineWidth   = 0.75;
      ctx.strokeRect(-this.size / 2, -this.size / 2, this.size, this.size);
      ctx.restore();
    }
  }

  class Triangle {
    x = 0; y = 0; size = 0; speed = 0;
    opacity = 0; rotation = 0; rotSpeed = 0;

    constructor() { this.reset(true); }

    reset(initial = false) {
      this.x        = rand(0, canvas.width);
      this.y        = initial ? rand(-canvas.height, canvas.height) : canvas.height + rand(30, 100);
      this.size     = rand(14, 48);
      this.speed    = rand(0.12, 0.45);
      this.opacity  = rand(0.08, 0.18);
      this.rotation = rand(0, Math.PI * 2);
      this.rotSpeed = (Math.random() - 0.5) * 0.002;
    }

    update() {
      this.y        -= this.speed;
      this.rotation += this.rotSpeed;
      if (this.y < -this.size * 2) this.reset();
    }

    draw() {
      ctx.save();
      ctx.translate(this.x, this.y);
      ctx.rotate(this.rotation);
      ctx.strokeStyle = PURPLE + this.opacity + ')';
      ctx.lineWidth   = 0.75;
      ctx.beginPath();
      ctx.moveTo(0, -this.size);
      ctx.lineTo( this.size * 0.866,  this.size * 0.5);
      ctx.lineTo(-this.size * 0.866,  this.size * 0.5);
      ctx.closePath();
      ctx.stroke();
      ctx.restore();
    }
  }

  class Dot {
    x = 0; y = 0; r = 0; speed = 0; opacity = 0;

    constructor() { this.reset(true); }

    reset(initial = false) {
      this.x       = rand(0, canvas.width);
      this.y       = initial ? rand(0, canvas.height) : canvas.height + rand(5, 30);
      this.r       = rand(1, 2.5);
      this.speed   = rand(0.3, 0.9);
      this.opacity = rand(0.12, 0.28);
    }

    update() {
      this.y -= this.speed;
      if (this.y < -5) this.reset();
    }

    draw() {
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2);
      ctx.strokeStyle = PURPLE + this.opacity + ')';
      ctx.lineWidth   = 0.75;
      ctx.stroke();
    }
  }

  /* ---- Init shapes ---- */
  const shapes: Array<Diamond | Triangle | Dot> = [
    ...Array.from({ length: 14 }, () => new Diamond()),
    ...Array.from({ length: 7  }, () => new Triangle()),
    ...Array.from({ length: 18 }, () => new Dot()),
  ];

  /* ---- Animation loop ---- */
  let rafId: number;

  function animate() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    for (const s of shapes) { s.update(); s.draw(); }
    rafId = requestAnimationFrame(animate);
  }

  animate();

  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      cancelAnimationFrame(rafId);
    } else {
      animate();
    }
  });
</script>
