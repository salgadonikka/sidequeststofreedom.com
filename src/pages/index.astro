---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import SiteFooter from '../components/SiteFooter.astro';
import { readingTime } from '../utils/readingTime';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const latestPost = posts[0] ?? null;
const recentPosts = posts.slice(1, 4);
---

<BaseLayout
  title="Side Quests To Freedom"
  description="Practical strategies, honest breakdowns, and real income reports for people building financial freedom one side hustle at a time."
  canonicalUrl="https://sidequeststofreedom.com"
>

  <!-- Animated geometric canvas background -->
  <canvas id="geo-canvas" aria-hidden="true"></canvas>

  <!-- Gradient mesh background -->
  <div class="lp-bg" aria-hidden="true"></div>

  <main class="lp-main">

    <!-- ===================== HERO ===================== -->
    <section class="hero" aria-label="Introduction">

      <!-- Left: profile picture -->
      <div class="hero-profile">
        <div class="avatar-wrap avatar-lg">
          <div class="avatar-ring" aria-hidden="true"></div>
          <div class="avatar-inner avatar-inner-lg">
            <!--<img
              src="/images/profilepicture.png"
              alt="Side Quests To Freedom"
              onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
            />-->
            <span class="avatar-placeholder">SQ</span>
          </div>
        </div>
      </div>

      <!-- Right: headline + CTA -->
      <div class="hero-content">
        <span class="hero-eyebrow">
          <span class="eyebrow-dot" aria-hidden="true"></span>
          Side Quests To Freedom
        </span>

        <h1 class="hero-headline">
          Building income stacks.<br>One <span class="headline-accent">side quest</span> at a time.
        </h1>

        <p class="hero-desc">
          For burned-out employees quietly building their escape plan. Real strategies, honest
          numbers, no overnight-success mythology.
        </p>

        <nav class="hero-nav" aria-label="Primary navigation">
          <a href="/blog" class="btn btn-primary">Read the Blog</a>
          <a href="/links" class="btn btn-secondary">My Links</a>
          <a href="#" class="btn btn-ghost">Newsletter</a>
        </nav>
      </div>

    </section>

    <!-- Scroll indicator -->
    <div class="scroll-hint" aria-hidden="true">
      <span class="scroll-hint-line"></span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"/>
      </svg>
    </div>

    <!-- ===================== LATEST POST ===================== -->
    {latestPost && (
      <section class="latest-section" aria-label="Latest post">
        <div class="section-label">
          <span class="section-dot" aria-hidden="true"></span>
          <span>Latest Post</span>
        </div>

        <a href={`/blog/${latestPost.slug}`} class="latest-card">
          <div class="latest-card-body">
            <div class="latest-meta">
              <time datetime={latestPost.data.pubDate.toISOString()}>
                {latestPost.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
              <span>·</span>
              <span>{readingTime(latestPost.body)} min read</span>
              {latestPost.data.tags && latestPost.data.tags.slice(0, 2).map((tag) => (
                <span class="latest-tag">{tag}</span>
              ))}
            </div>
            <h2 class="latest-title">{latestPost.data.title}</h2>
            <p class="latest-excerpt">{latestPost.data.description}</p>
          </div>
          <span class="latest-read-more" aria-label={`Read ${latestPost.data.title}`}>
            Read more <span aria-hidden="true">&#8594;</span>
          </span>
        </a>

        {recentPosts.length > 0 && (
          <ul class="recent-list" role="list" aria-label="More recent posts">
            {recentPosts.map((post) => (
              <li>
                <a href={`/blog/${post.slug}`} class="recent-item">
                  <span class="recent-title">{post.data.title}</span>
                  <span class="recent-right">
                    <time class="recent-date" datetime={post.data.pubDate.toISOString()}>
                      {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                    </time>
                    <span class="recent-arrow" aria-hidden="true">&#8594;</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        )}
      </section>
    )}

    <!-- ===================== WHAT YOU'LL FIND ===================== -->
    <section class="topics-section" aria-label="What you'll find here">
      <div class="section-label">
        <span class="section-dot" aria-hidden="true"></span>
        <span>What You'll Find Here</span>
      </div>

      <p class="topics-intro">
        Side Quests To Freedom covers the practical side of building income outside your day job —
        no recycled advice, no overnight-success mythology. Just honest guides, real numbers, and
        the strategies that hold up over time.
      </p>

      <ul class="topics-grid" role="list">
        <li class="topic-card">
          <div class="topic-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          </div>
          <div class="topic-body">
            <h3 class="topic-title">Side Hustle Guides</h3>
            <p class="topic-desc">
              Step-by-step breakdowns of specific side hustles — what they actually involve, how
              much you can realistically earn, and how to get started without quitting your job.
            </p>
          </div>
        </li>

        <li class="topic-card">
          <div class="topic-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/>
              <line x1="6" y1="20" x2="6" y2="14"/>
            </svg>
          </div>
          <div class="topic-body">
            <h3 class="topic-title">Income Reports</h3>
            <p class="topic-desc">
              Transparent breakdowns of what's earning, what flopped, and why. Real figures help
              you calibrate your expectations and avoid the traps that waste months of effort.
            </p>
          </div>
        </li>

        <li class="topic-card">
          <div class="topic-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 8v4l3 3"/>
            </svg>
          </div>
          <div class="topic-body">
            <h3 class="topic-title">Strategy & Systems</h3>
            <p class="topic-desc">
              How to manage a side hustle alongside a full-time job without burning out — time
              management, prioritisation, and building systems that compound over months, not days.
            </p>
          </div>
        </li>

        <li class="topic-card">
          <div class="topic-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2"/>
              <path d="M8 21h8M12 17v4"/>
            </svg>
          </div>
          <div class="topic-body">
            <h3 class="topic-title">Tools & Resources</h3>
            <p class="topic-desc">
              Honest reviews of the platforms, apps, and services worth using — and the ones to
              skip. Only tools that have been tested in practice make the list.
            </p>
          </div>
        </li>
      </ul>

      <a href="/blog" class="topics-cta">
        Browse all posts <span aria-hidden="true">&#8594;</span>
      </a>
    </section>

    <SiteFooter />

  </main>

</BaseLayout>

<style>
  /* ---- Gradient mesh background ---- */
  .lp-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 70% 60% at 0% 0%,   rgba(110, 86, 207, 0.08) 0%, transparent 70%),
      radial-gradient(ellipse 45% 45% at 100% 100%, rgba(0, 229, 160, 0.08) 0%, transparent 65%),
      #060610;
  }

  /* ---- Canvas ---- */
  #geo-canvas {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  /* ---- Layout ---- */
  .lp-main {
    position: relative;
    z-index: 2;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    max-width: 1100px;
    margin: 0 auto;
    padding: 2.5rem 2.5rem 4rem;
    gap: 0;
  }

  /* ---- Hero ---- */
  .hero {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    align-items: center;
    gap: 5rem;
    padding: 1rem 0 2rem;
    min-height: calc(100vh - 52px - 5rem); /* full viewport minus nav */
  }

  /* ---- Profile side ---- */
  .hero-profile {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .avatar-lg {
    width: 240px !important;
    height: 240px !important;
  }

  .avatar-lg .avatar-ring {
    inset: -5px;
  }

  .avatar-inner-lg {
    width: 240px !important;
    height: 240px !important;
    outline-width: 5px !important;
  }

  .avatar-inner-lg .avatar-placeholder {
    font-size: 5.5rem;
  }

  /* ---- Content side ---- */
  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 1.35rem;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(226, 226, 240, 0.35);
  }

  .eyebrow-dot {
    width: 5px;
    height: 5px;
    background: #6E56CF;
    border-radius: 1px;
    transform: rotate(45deg);
    flex-shrink: 0;
  }

  .hero-headline {
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 700;
    color: #E2E2F0;
    letter-spacing: -0.03em;
    line-height: 1.12;
  }

  .headline-accent {
    background: linear-gradient(90deg, #6E56CF 0%, #00E5A0 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-desc {
    font-size: 1rem;
    color: rgba(226, 226, 240, 0.5);
    line-height: 1.7;
    max-width: 440px;
  }

  /* ---- Buttons ---- */
  .hero-nav {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    margin-top: 0.25rem;
    max-width: 340px;
  }

  .btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 0.85rem 1.4rem;
    border-radius: 10px;
    text-decoration: none;
    border: 1px solid transparent;
    transition: background 0.2s ease, border-color 0.2s ease,
                transform 0.15s ease, box-shadow 0.2s ease;
  }

  .btn::after {
    content: '→';
    font-size: 1rem;
    opacity: 0.5;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .btn:hover::after {
    transform: translateX(3px);
    opacity: 1;
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn-primary {
    background: #6E56CF;
    color: #fff;
    box-shadow: 0 4px 18px rgba(110, 86, 207, 0.35);
  }

  .btn-primary:hover {
    background: #7d67d8;
    box-shadow: 0 6px 28px rgba(110, 86, 207, 0.55);
  }

  .btn-secondary {
    background: rgba(110, 86, 207, 0.1);
    border-color: rgba(110, 86, 207, 0.35);
    color: #E2E2F0;
  }

  .btn-secondary:hover {
    background: rgba(110, 86, 207, 0.18);
    border-color: rgba(110, 86, 207, 0.55);
  }

  .btn-ghost {
    background: transparent;
    border-color: rgba(226, 226, 240, 0.1);
    color: rgba(226, 226, 240, 0.45);
  }

  .btn-ghost:hover {
    border-color: rgba(0, 229, 160, 0.35);
    color: #00E5A0;
  }

  /* ---- Scroll hint ---- */
  .scroll-hint {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    color: rgba(110, 86, 207, 0.4);
    margin-bottom: 3rem;
    animation: bounce-hint 2.4s ease-in-out infinite;
  }

  .scroll-hint-line {
    display: block;
    width: 1px;
    height: 28px;
    background: linear-gradient(to bottom, transparent, rgba(110, 86, 207, 0.4));
  }

  @keyframes bounce-hint {
    0%, 100% { transform: translateY(0); opacity: 0.7; }
    50%       { transform: translateY(5px); opacity: 1; }
  }

  /* ---- Latest post section ---- */
  .latest-section {
    padding-top: 2rem;
    padding-bottom: 3rem;
    border-top: 1px solid rgba(226, 226, 240, 0.06);
  }

  .latest-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    margin-top: 1rem;
    padding: 1.5rem 1.75rem;
    background: rgba(110, 86, 207, 0.06);
    border: 1px solid rgba(110, 86, 207, 0.18);
    border-radius: 14px;
    text-decoration: none;
    color: #E2E2F0;
    transition: background 0.2s ease, border-color 0.2s ease,
                transform 0.2s ease, box-shadow 0.2s ease;
    position: relative;
  }

  .latest-card::before {
    content: '';
    position: absolute;
    top: -1px; left: -1px;
    width: 14px; height: 14px;
    border-top: 2px solid #6E56CF;
    border-left: 2px solid #6E56CF;
    border-radius: 2px 0 0 0;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .latest-card::after {
    content: '';
    position: absolute;
    bottom: -1px; right: -1px;
    width: 14px; height: 14px;
    border-bottom: 2px solid #6E56CF;
    border-right: 2px solid #6E56CF;
    border-radius: 0 0 2px 0;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .latest-card:hover {
    background: rgba(110, 86, 207, 0.12);
    border-color: rgba(110, 86, 207, 0.35);
    transform: translateY(-2px);
    box-shadow: 0 10px 40px rgba(110, 86, 207, 0.18);
  }

  .latest-card:hover::before,
  .latest-card:hover::after {
    opacity: 1;
  }

  .latest-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 0;
  }

  .latest-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-size: 0.72rem;
    color: rgba(226, 226, 240, 0.3);
  }

  .latest-tag {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #6E56CF;
    background: rgba(110, 86, 207, 0.12);
    border: 1px solid rgba(110, 86, 207, 0.2);
    border-radius: 3px;
    padding: 0.1rem 0.4rem;
  }

  .latest-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: #E2E2F0;
    letter-spacing: -0.02em;
    line-height: 1.3;
  }

  .latest-excerpt {
    font-size: 0.875rem;
    color: rgba(226, 226, 240, 0.45);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    max-width: 600px;
  }

  .latest-read-more {
    font-size: 0.82rem;
    font-weight: 600;
    color: #6E56CF;
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 0.2s;
  }

  .latest-card:hover .latest-read-more {
    color: #00E5A0;
  }

  /* ---- Recent posts list ---- */
  .recent-list {
    list-style: none;
    margin-top: 0.65rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .recent-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.7rem 0.5rem;
    border-bottom: 1px solid rgba(226, 226, 240, 0.05);
    text-decoration: none;
    color: #E2E2F0;
    transition: padding-left 0.2s;
  }

  .recent-item:hover {
    padding-left: 0.85rem;
  }

  .recent-title {
    font-size: 0.875rem;
    font-weight: 500;
    color: rgba(226, 226, 240, 0.65);
    transition: color 0.2s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }

  .recent-item:hover .recent-title {
    color: #E2E2F0;
  }

  .recent-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .recent-date {
    font-size: 0.72rem;
    color: rgba(226, 226, 240, 0.25);
    white-space: nowrap;
  }

  .recent-arrow {
    font-size: 0.85rem;
    color: rgba(110, 86, 207, 0.35);
    transition: color 0.2s, transform 0.2s;
  }

  .recent-item:hover .recent-arrow {
    color: #6E56CF;
    transform: translateX(3px);
  }

  /* ---- Topics section ---- */
  .topics-section {
    padding-top: 2rem;
    padding-bottom: 1rem;
    border-top: 1px solid rgba(226, 226, 240, 0.06);
  }

  .topics-intro {
    font-size: 0.925rem;
    color: rgba(226, 226, 240, 0.45);
    line-height: 1.75;
    margin: 0.85rem 0 1.75rem;
    max-width: 680px;
  }

  .topics-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.85rem;
    list-style: none;
    margin-bottom: 1.5rem;
  }

  .topic-card {
    display: flex;
    gap: 0.9rem;
    padding: 1.1rem 1.25rem;
    background: rgba(110, 86, 207, 0.05);
    border: 1px solid rgba(110, 86, 207, 0.12);
    border-radius: 12px;
    transition: background 0.2s, border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }

  .topic-card:hover {
    background: rgba(110, 86, 207, 0.1);
    border-color: rgba(110, 86, 207, 0.28);
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(110, 86, 207, 0.12);
  }

  .topic-icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(110, 86, 207, 0.1);
    border-radius: 8px;
    color: #6E56CF;
    margin-top: 1px;
    transition: background 0.2s;
  }

  .topic-card:hover .topic-icon {
    background: rgba(110, 86, 207, 0.2);
  }

  .topic-body {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .topic-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: #E2E2F0;
    letter-spacing: -0.01em;
  }

  .topic-desc {
    font-size: 0.815rem;
    color: rgba(226, 226, 240, 0.42);
    line-height: 1.65;
  }

  .topics-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.83rem;
    font-weight: 600;
    color: rgba(110, 86, 207, 0.65);
    text-decoration: none;
    transition: color 0.2s;
  }

  .topics-cta:hover {
    color: #6E56CF;
  }

  /* ---- Responsive ---- */
  @media (max-width: 860px) {
    .lp-main {
      padding: 2rem 1.75rem 3.5rem;
    }

    .hero {
      grid-template-columns: 1fr 1.5fr;
      gap: 3rem;
      min-height: auto;
      padding-bottom: 1.5rem;
    }

    .avatar-lg {
      width: 180px !important;
      height: 180px !important;
    }

    .avatar-inner-lg {
      width: 180px !important;
      height: 180px !important;
    }

    .avatar-inner-lg .avatar-placeholder {
      font-size: 4rem;
    }
  }

  @media (max-width: 640px) {
    .lp-main {
      padding: 2rem 1.25rem 3rem;
    }

    .hero {
      grid-template-columns: 1fr;
      gap: 1.75rem;
      padding-bottom: 1rem;
    }

    .hero-profile {
      order: -1;
    }

    .avatar-lg {
      width: 140px !important;
      height: 140px !important;
    }

    .avatar-inner-lg {
      width: 140px !important;
      height: 140px !important;
    }

    .avatar-inner-lg .avatar-placeholder {
      font-size: 3rem;
    }

    .hero-nav {
      max-width: 100%;
    }

    .scroll-hint {
      display: none;
    }

    .latest-card {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
      padding: 1.1rem 1.25rem;
    }

    .topics-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ---- Reduced motion ---- */
  @media (prefers-reduced-motion: reduce) {
    #geo-canvas { display: none; }
    .scroll-hint { animation: none; }
    .btn:hover { transform: none; }
    .latest-card:hover { transform: none; }
    .topic-card:hover { transform: none; }
  }
</style>

<script>
  const canvas = document.getElementById('geo-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  function getCanvasColors() {
    const style = getComputedStyle(document.documentElement);
    const p = style.getPropertyValue('--purple-rgb').trim() || '110, 86, 207';
    const g = style.getPropertyValue('--green-rgb').trim() || '0, 229, 160';
    return { PURPLE: `rgba(${p}, `, GREEN: `rgba(${g}, ` };
  }
  let { PURPLE, GREEN } = getCanvasColors();

  // Update colors when theme changes
  const themeObserver = new MutationObserver(() => {
    ({ PURPLE, GREEN } = getCanvasColors());
  });
  themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

  function resize() {
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  function rand(min: number, max: number) {
    return Math.random() * (max - min) + min;
  }

  /* ---- Shape classes ---- */
  class Diamond {
    x = 0; y = 0; size = 0; speed = 0;
    opacity = 0; color = PURPLE; rotation = 0; rotSpeed = 0;

    constructor() { this.reset(true); }

    reset(initial = false) {
      this.x        = rand(0, canvas.width);
      this.y        = initial ? rand(-canvas.height, canvas.height) : canvas.height + rand(20, 80);
      this.size     = rand(8, 38);
      this.speed    = rand(0.2, 0.75);
      this.opacity  = rand(0.1, 0.22);
      this.color    = Math.random() > 0.85 ? GREEN : PURPLE;
      this.rotation = rand(0, Math.PI * 2);
      this.rotSpeed = (Math.random() - 0.5) * 0.004;
    }

    update() {
      this.y        -= this.speed;
      this.rotation += this.rotSpeed;
      if (this.y < -this.size * 2) this.reset();
    }

    draw() {
      ctx.save();
      ctx.translate(this.x, this.y);
      ctx.rotate(this.rotation + Math.PI / 4);
      ctx.strokeStyle = this.color + this.opacity + ')';
      ctx.lineWidth   = 0.75;
      ctx.strokeRect(-this.size / 2, -this.size / 2, this.size, this.size);
      ctx.restore();
    }
  }

  class Triangle {
    x = 0; y = 0; size = 0; speed = 0;
    opacity = 0; rotation = 0; rotSpeed = 0;

    constructor() { this.reset(true); }

    reset(initial = false) {
      this.x        = rand(0, canvas.width);
      this.y        = initial ? rand(-canvas.height, canvas.height) : canvas.height + rand(30, 100);
      this.size     = rand(14, 48);
      this.speed    = rand(0.12, 0.45);
      this.opacity  = rand(0.08, 0.18);
      this.rotation = rand(0, Math.PI * 2);
      this.rotSpeed = (Math.random() - 0.5) * 0.002;
    }

    update() {
      this.y        -= this.speed;
      this.rotation += this.rotSpeed;
      if (this.y < -this.size * 2) this.reset();
    }

    draw() {
      ctx.save();
      ctx.translate(this.x, this.y);
      ctx.rotate(this.rotation);
      ctx.strokeStyle = PURPLE + this.opacity + ')';
      ctx.lineWidth   = 0.75;
      ctx.beginPath();
      ctx.moveTo(0, -this.size);
      ctx.lineTo( this.size * 0.866,  this.size * 0.5);
      ctx.lineTo(-this.size * 0.866,  this.size * 0.5);
      ctx.closePath();
      ctx.stroke();
      ctx.restore();
    }
  }

  class Dot {
    x = 0; y = 0; r = 0; speed = 0; opacity = 0;

    constructor() { this.reset(true); }

    reset(initial = false) {
      this.x       = rand(0, canvas.width);
      this.y       = initial ? rand(0, canvas.height) : canvas.height + rand(5, 30);
      this.r       = rand(1, 2.5);
      this.speed   = rand(0.3, 0.9);
      this.opacity = rand(0.12, 0.28);
    }

    update() {
      this.y -= this.speed;
      if (this.y < -5) this.reset();
    }

    draw() {
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2);
      ctx.strokeStyle = PURPLE + this.opacity + ')';
      ctx.lineWidth   = 0.75;
      ctx.stroke();
    }
  }

  /* ---- Init shapes ---- */
  const shapes: Array<Diamond | Triangle | Dot> = [
    ...Array.from({ length: 14 }, () => new Diamond()),
    ...Array.from({ length: 7  }, () => new Triangle()),
    ...Array.from({ length: 18 }, () => new Dot()),
  ];

  /* ---- Animation loop ---- */
  let rafId: number;

  function animate() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    for (const s of shapes) { s.update(); s.draw(); }
    rafId = requestAnimationFrame(animate);
  }

  animate();

  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      cancelAnimationFrame(rafId);
    } else {
      animate();
    }
  });
</script>
