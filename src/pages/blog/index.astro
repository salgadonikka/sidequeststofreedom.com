---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { readingTime } from '../../utils/readingTime';
import AdUnit from '../../components/AdUnit.astro';
import SiteFooter from '../../components/SiteFooter.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const allTags = [...new Set(posts.flatMap((p) => p.data.tags ?? []))].sort();
const totalMinutes = posts.reduce((sum, p) => sum + readingTime(p.body), 0);

const [featured, ...rest] = posts;
---

<BaseLayout
  title="Blog — Side Quests To Freedom"
  description="Guides, strategies, and real talk on building financial freedom through side hustles."
  canonicalUrl="https://sidequeststofreedom.com/blog"
>
  <div class="bg-grid" aria-hidden="true"></div>
  <div class="bg-orb bg-orb-1" aria-hidden="true"></div>
  <div class="bg-orb bg-orb-2" aria-hidden="true"></div>

  <main class="blog-outer">

    <!-- Left: post list -->
    <div class="blog-main">
      <header class="blog-header">
        <a href="/" class="back-link">&#8592; Home</a>
        <div class="blog-header-row">
          <div>
            <h1 class="site-name" style="margin-top: 1.5rem;">Blog</h1>
            <p class="tagline">Guides, strategies, and real talk on building financial freedom.</p>
          </div>
          <div class="blog-stats">
            <div class="stat">
              <span class="stat-num">{posts.length}</span>
              <span class="stat-label">posts</span>
            </div>
            <div class="stat">
              <span class="stat-num">{totalMinutes}</span>
              <span class="stat-label">min reading</span>
            </div>
            <a href="/search" class="search-link" aria-label="Search posts">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              Search
            </a>
          </div>
        </div>
      </header>

      <!-- Tag filter: mobile only (sidebar has it on desktop) -->
      {allTags.length > 0 && (
        <div class="tag-filter tag-filter--inline" role="group" aria-label="Filter by tag">
          <button class="tag-btn active" data-tag="all">All</button>
          {allTags.map((tag) => (
            <button class="tag-btn" data-tag={tag}>{tag}</button>
          ))}
        </div>
      )}

      {posts.length === 0 ? (
        <p class="empty-state">No posts yet — check back soon.</p>
      ) : (
        <>
          {featured && (
            <a
              href={`/blog/${featured.slug}`}
              class="featured-card post-item"
              data-tags={JSON.stringify(featured.data.tags ?? [])}
            >
              <div class="featured-body">
                <span class="featured-eyebrow">Latest post</span>
                <h2 class="featured-title">{featured.data.title}</h2>
                <p class="featured-desc">{featured.data.description}</p>
                <div class="featured-meta">
                  <time datetime={featured.data.pubDate.toISOString()}>
                    {featured.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                  </time>
                  <span>·</span>
                  <span>{readingTime(featured.body)} min read</span>
                  {featured.data.tags && featured.data.tags.map((tag) => (
                    <span class="featured-tag">{tag}</span>
                  ))}
                </div>
              </div>
              <span class="featured-arrow" aria-hidden="true">&#8594;</span>
            </a>
          )}

          {rest.length > 0 && (
            <section class="posts-grid" aria-label="All posts">
              {rest.map((post) => {
                const date = post.data.pubDate.toLocaleDateString('en-US', {
                  year: 'numeric', month: 'short', day: 'numeric',
                });
                return (
                  <a
                    href={`/blog/${post.slug}`}
                    class="post-card post-item"
                    data-tags={JSON.stringify(post.data.tags ?? [])}
                  >
                    <div class="post-card-body">
                      <span class="link-title">{post.data.title}</span>
                      <span class="link-sub">{post.data.description}</span>
                      {post.data.tags && post.data.tags.length > 0 && (
                        <ul class="post-tag-list" aria-label="Tags">
                          {post.data.tags.map((tag) => <li class="post-tag">{tag}</li>)}
                        </ul>
                      )}
                    </div>
                    <div class="post-card-meta">
                      <time datetime={post.data.pubDate.toISOString()} class="post-date">{date}</time>
                      <span class="read-time">{readingTime(post.body)} min</span>
                      <span class="link-arrow" aria-hidden="true">&#8594;</span>
                    </div>
                  </a>
                );
              })}
            </section>
          )}

          <p class="no-results" aria-live="polite" style="display:none">No posts for this tag.</p>
        </>
      )}

      <SiteFooter />
    </div>

    <!-- Right: sidebar with tags + ad -->
    <aside class="blog-sidebar">
      <div class="sidebar-sticky">
        {allTags.length > 0 && (
          <div class="sidebar-tags">
            <p class="sidebar-section-label">Filter by tag</p>
            <div class="tag-filter" role="group" aria-label="Filter by tag">
              <button class="tag-btn active" data-tag="all">All</button>
              {allTags.map((tag) => (
                <button class="tag-btn" data-tag={tag}>{tag}</button>
              ))}
            </div>
          </div>
        )}
        <div class="sidebar-ad">
          <AdUnit slot="1380933491" format="rectangle" />
        </div>
      </div>
    </aside>

  </main>
</BaseLayout>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
  const items = document.querySelectorAll<HTMLElement>('.post-item');
  const noResults = document.querySelector<HTMLElement>('.no-results');

  btns.forEach((btn) => {
    btn.addEventListener('click', () => {
      // sync all tag buttons across both inline + sidebar sets
      const tag = btn.dataset.tag ?? 'all';
      btns.forEach((b) => {
        b.classList.toggle('active', b.dataset.tag === tag);
      });

      let visible = 0;
      items.forEach((item) => {
        const tags: string[] = JSON.parse(item.dataset.tags ?? '[]');
        const show = tag === 'all' || tags.includes(tag);
        (item as HTMLElement).style.display = show ? '' : 'none';
        if (show) visible++;
      });

      if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
    });
  });
</script>

<style>
  /* ---- Outer layout ---- */
  .blog-outer {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 220px;
    gap: 2.5rem;
    align-items: start;
    max-width: 940px;
    margin: 0 auto;
    padding: 3.5rem 1.5rem 4rem;
    position: relative;
    z-index: 1;
  }

  .blog-main {
    min-width: 0;
    overflow: hidden;
  }

  .blog-sidebar {
    display: block;
  }

  .sidebar-sticky {
    position: sticky;
    top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .sidebar-section-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(226, 226, 240, 0.3);
    margin-bottom: 0.6rem;
  }

  .sidebar-tags {
    padding: 1rem;
    background: rgba(110, 86, 207, 0.04);
    border: 1px solid rgba(110, 86, 207, 0.12);
    border-radius: 10px;
  }

  @media (max-width: 760px) {
    .blog-outer {
      grid-template-columns: 1fr;
      max-width: 560px;
    }

    .blog-sidebar {
      display: none;
    }
  }

  /* ---- Header ---- */
  .blog-header {
    margin-bottom: 1.75rem;
  }

  .blog-header-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .back-link {
    font-size: 0.8rem;
    color: rgba(110, 86, 207, 0.6);
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: #6E56CF;
  }

  .blog-stats {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding-bottom: 0.25rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1.2;
  }

  .stat-num {
    font-size: 1.1rem;
    font-weight: 700;
    color: #E2E2F0;
  }

  .stat-label {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(226, 226, 240, 0.3);
  }

  .search-link {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    color: rgba(110, 86, 207, 0.7);
    text-decoration: none;
    border: 1px solid rgba(110, 86, 207, 0.2);
    border-radius: 6px;
    padding: 0.3rem 0.7rem;
    transition: color 0.2s, border-color 0.2s;
  }

  .search-link:hover {
    color: #6E56CF;
    border-color: rgba(110, 86, 207, 0.4);
  }

  /* ---- Tag filter ---- */
  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  /* Must come after .tag-filter so display:none wins */
  .tag-filter--inline {
    display: none;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 760px) {
    .tag-filter--inline {
      display: flex;
    }
  }

  .tag-btn {
    font-family: inherit;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(226, 226, 240, 0.45);
    background: transparent;
    border: 1px solid rgba(226, 226, 240, 0.1);
    border-radius: 5px;
    padding: 0.25rem 0.6rem;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .tag-btn:hover,
  .tag-btn.active {
    color: #6E56CF;
    border-color: rgba(110, 86, 207, 0.35);
    background: rgba(110, 86, 207, 0.08);
  }

  /* ---- Featured card ---- */
  .featured-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem;
    background: rgba(110, 86, 207, 0.07);
    border: 1px solid rgba(110, 86, 207, 0.2);
    border-radius: 12px;
    text-decoration: none;
    margin-bottom: 1rem;
    transition: border-color 0.2s, background 0.2s;
  }

  .featured-card:hover {
    border-color: rgba(110, 86, 207, 0.45);
    background: rgba(110, 86, 207, 0.12);
  }

  .featured-body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-width: 0;
  }

  .featured-eyebrow {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #00E5A0;
  }

  .featured-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: #E2E2F0;
    letter-spacing: -0.02em;
    line-height: 1.25;
  }

  .featured-desc {
    font-size: 0.855rem;
    color: rgba(226, 226, 240, 0.55);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .featured-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-size: 0.72rem;
    color: rgba(226, 226, 240, 0.35);
    margin-top: 0.1rem;
  }

  .featured-tag {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #6E56CF;
    background: rgba(110, 86, 207, 0.12);
    border: 1px solid rgba(110, 86, 207, 0.2);
    border-radius: 3px;
    padding: 0.1rem 0.4rem;
  }

  .featured-arrow {
    font-size: 1.1rem;
    color: rgba(110, 86, 207, 0.4);
    flex-shrink: 0;
    transition: color 0.2s;
  }

  .featured-card:hover .featured-arrow {
    color: #6E56CF;
  }

  /* ---- Posts grid ---- */
  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    width: 100%;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.9rem 1rem;
    background: rgba(110, 86, 207, 0.07);
    border: 1px solid rgba(110, 86, 207, 0.18);
    border-radius: 10px;
    text-decoration: none;
    color: #E2E2F0;
    min-width: 0;
    transition: background 0.2s, border-color 0.2s;
  }

  .post-card:hover {
    background: rgba(110, 86, 207, 0.12);
    border-color: rgba(110, 86, 207, 0.35);
  }

  .post-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
    flex: 1;
  }

  .post-card-body .link-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: #E2E2F0;
    line-height: 1.35;
  }

  .post-card-body .link-sub {
    font-size: 0.8rem;
    color: rgba(226, 226, 240, 0.5);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 0.25rem;
  }

  .post-date {
    font-size: 0.7rem;
    color: rgba(226, 226, 240, 0.3);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .read-time {
    font-size: 0.68rem;
    color: rgba(226, 226, 240, 0.25);
    white-space: nowrap;
  }

  .link-arrow {
    margin-left: auto;
    font-size: 0.9rem;
    color: rgba(110, 86, 207, 0.4);
    transition: color 0.2s;
  }

  .post-card:hover .link-arrow {
    color: #6E56CF;
  }

  .post-tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    list-style: none;
    margin-top: 0.25rem;
  }

  .post-tag {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #6E56CF;
    background: rgba(110, 86, 207, 0.1);
    border: 1px solid rgba(110, 86, 207, 0.18);
    border-radius: 3px;
    padding: 0.15rem 0.4rem;
  }

  .no-results {
    font-size: 0.875rem;
    color: rgba(226, 226, 240, 0.35);
    text-align: center;
    padding: 2rem 0;
  }

  .empty-state {
    font-size: 0.875rem;
    color: rgba(226, 226, 240, 0.35);
    text-align: center;
    padding: 3rem 0;
  }

  @media (max-width: 500px) {
    .blog-header-row {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
