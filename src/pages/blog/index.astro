---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const year = new Date().getFullYear();
---

<BaseLayout
  title="Blog — Side Quests To Freedom"
  description="Guides, strategies, and real talk on building financial freedom through side hustles."
  canonicalUrl="https://sidequeststofreedom.com/blog"
>
  <div class="bg-grid" aria-hidden="true"></div>
  <div class="bg-orb bg-orb-1" aria-hidden="true"></div>
  <div class="bg-orb bg-orb-2" aria-hidden="true"></div>

  <main class="container">

    <header class="blog-header">
      <a href="/" class="back-link">&#8592; Home</a>
      <h1 class="site-name" style="margin-top: 1.5rem;">Blog</h1>
      <p class="tagline">Guides, strategies, and real talk on building financial freedom.</p>
    </header>

    {posts.length === 0 ? (
      <p class="empty-state">No posts yet — check back soon.</p>
    ) : (
      <section class="links-section" aria-label="All posts">
        {posts.map((post) => {
          const date = post.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric', month: 'short', day: 'numeric',
          });
          return (
            <a href={`/blog/${post.slug}`} class="link-card post-card is-visible">
              <div class="post-card-body">
                <span class="link-title">{post.data.title}</span>
                <span class="link-sub">{post.data.description}</span>
                {post.data.tags && post.data.tags.length > 0 && (
                  <ul class="post-tag-list" aria-label="Tags">
                    {post.data.tags.map((tag) => <li class="post-tag">{tag}</li>)}
                  </ul>
                )}
              </div>
              <div class="post-card-meta">
                <time datetime={post.data.pubDate.toISOString()} class="post-date">{date}</time>
                <span class="link-arrow" aria-hidden="true">&#8594;</span>
              </div>
            </a>
          );
        })}
      </section>
    )}

    <footer class="site-footer">
      <p>&copy; {year} Side Quests To Freedom</p>
      <a href="https://sidequeststofreedom.com" class="footer-link">sidequeststofreedom.com</a>
    </footer>

  </main>
</BaseLayout>

<style>
  .blog-header {
    margin-bottom: 2.5rem;
  }

  .back-link {
    font-size: 0.8rem;
    color: rgba(110, 86, 207, 0.6);
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: #6E56CF;
  }

  .empty-state {
    font-size: 0.875rem;
    color: rgba(226, 226, 240, 0.35);
    text-align: center;
    padding: 3rem 0;
  }

  .post-card {
    align-items: flex-start;
    gap: 0.75rem;
  }

  .post-card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
  }

  .post-card-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .post-date {
    font-size: 0.7rem;
    color: rgba(226, 226, 240, 0.3);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .post-tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    list-style: none;
    margin-top: 0.25rem;
  }

  .post-tag {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #6E56CF;
    background: rgba(110, 86, 207, 0.1);
    border: 1px solid rgba(110, 86, 207, 0.18);
    border-radius: 3px;
    padding: 0.15rem 0.4rem;
  }
</style>
