---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LinkCard from '../../components/LinkCard.astro';
import SiteFooter from '../../components/SiteFooter.astro';
---

<BaseLayout
  title="Links — Side Quests To Freedom"
  description="All links for Side Quests To Freedom — your strategic guide to financial freedom through side hustles."
  canonicalUrl="https://sidequeststofreedom.com/links"
>
  <!-- Background layers -->
  <div class="bg-grid" aria-hidden="true"></div>
  <div class="bg-orb bg-orb-1" aria-hidden="true"></div>
  <div class="bg-orb bg-orb-2" aria-hidden="true"></div>

  <main class="container">

    <!-- ===================== PROFILE ===================== -->
    <section class="profile">
      <div class="avatar-wrap">
        <div class="avatar-ring" aria-hidden="true"></div>
        <div class="avatar-inner">
          <!--<img src="/images/profilepicture.png" alt="Side Quests To Freedom" />-->
          <span class="avatar-placeholder">SQ</span>
        </div>
      </div>

      <h1 class="site-name">Side Quests To Freedom</h1>
      <p class="tagline">Turning side hustles into financial freedom — one quest at a time.</p>
    </section>

    <!-- ===================== FEATURED ===================== -->
    <section class="links-section" aria-label="Featured">
      <div class="section-label">
        <span class="section-dot" aria-hidden="true"></span>
        <span>Featured</span>
      </div>

      <!-- UPDATE: Change href to your "Start Here" page or latest content URL. -->
      <LinkCard
        href="/"
        title="Start Here"
        sub="Your roadmap to financial freedom"
        ariaLabel="Start Here — your roadmap to financial freedom"
        featured
      >
        <!-- Map / Compass icon -->
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.8"/>
          <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" fill="none"/>
        </svg>
      </LinkCard>
    </section>

    <!-- ===================== SOCIAL LINKS ===================== -->
    <section class="links-section" aria-label="Follow Along">
      <div class="section-label">
        <span class="section-dot" aria-hidden="true"></span>
        <span>Follow Along</span>
      </div>

      <LinkCard href="https://www.instagram.com/sidequeststofreedom/" title="Instagram" sub="@sidequeststofreedom" ariaLabel="Instagram — @sidequeststofreedom">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5.5" stroke="currentColor" stroke-width="1.8"/>
          <circle cx="12" cy="12" r="4.5" stroke="currentColor" stroke-width="1.8"/>
          <circle cx="17.6" cy="6.4" r="1.1" fill="currentColor"/>
        </svg>
      </LinkCard>

      <LinkCard href="https://www.tiktok.com/@sidequeststofreedom" title="TikTok" sub="@sidequeststofreedom" ariaLabel="TikTok — @sidequeststofreedom">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </LinkCard>

      <LinkCard href="https://www.youtube.com/@SideQuestsToFreedom" title="YouTube" sub="Side Quests To Freedom" ariaLabel="YouTube — Side Quests To Freedom">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="2" y="5" width="20" height="14" rx="3.5" stroke="currentColor" stroke-width="1.8"/>
          <path d="M10 9.5l5 2.5-5 2.5V9.5z" fill="currentColor"/>
        </svg>
      </LinkCard>

      <!--<LinkCard href="#" title="X (Twitter)" sub="@sidequestst2frdm" ariaLabel="X (Twitter) — @sidequeststofreedom">
        <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.632L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
        </svg>
      </LinkCard>-->

      <LinkCard href="https://www.pinterest.com/sidequeststofreedom/" title="Pinterest" sub="Side Quests To Freedom" ariaLabel="Pinterest — Side Quests To Freedom">
        <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.047 2.427 7.532 5.94 9.079-.082-.735-.156-1.862.033-2.665.17-.726 1.136-4.817 1.136-4.817s-.29-.58-.29-1.437c0-1.347.782-2.354 1.754-2.354.828 0 1.228.621 1.228 1.366 0 .832-.53 2.076-.804 3.23-.228.965.484 1.75 1.432 1.75 1.718 0 3.044-1.813 3.044-4.425 0-2.314-1.664-3.932-4.041-3.932-2.753 0-4.37 2.065-4.37 4.199 0 .83.32 1.72.72 2.205a.29.29 0 0 1 .067.277l-.268 1.1c-.043.177-.141.215-.324.13-1.21-.564-1.967-2.335-1.967-3.757 0-3.059 2.22-5.872 6.408-5.872 3.365 0 5.98 2.399 5.98 5.603 0 3.342-2.109 6.032-5.035 6.032-.983 0-1.908-.511-2.224-1.113l-.604 2.307c-.22.843-.811 1.9-1.207 2.544.91.281 1.874.433 2.873.433 5.523 0 10-4.477 10-10S17.523 2 12 2z"/>
        </svg>
      </LinkCard>

      <LinkCard href="#" title="Newsletter" sub="Free weekly side hustle intel" ariaLabel="Newsletter — Join the free weekly email">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="2" y="5" width="20" height="14" rx="3" stroke="currentColor" stroke-width="1.8"/>
          <path d="M2 9l10 6 10-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </LinkCard>
    </section>

    <!--
      FUTURE SECTION: DISCOUNT CODES
      Uncomment when you have deals to share.

    <section class="links-section" aria-label="Deals &amp; Discount Codes">
      <div class="section-label">
        <span class="section-dot" aria-hidden="true"></span>
        <span>Deals &amp; Discount Codes</span>
      </div>

      <div class="link-card promo" aria-label="Brand Name discount code">
        <div class="link-icon">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2"
              stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="link-content">
          <span class="link-title">Brand Name</span>
          <span class="link-sub">20% off — click to copy code</span>
        </div>
        <button class="promo-badge" data-code="SIDEQUESTS"
                onclick="copyCode(this)" aria-label="Copy discount code SIDEQUESTS">
          SIDEQUESTS
        </button>
      </div>
    </section>
    -->

    <!--
      FUTURE SECTION: PRODUCTS & RESOURCES
      Uncomment when you have products or resources to showcase.

    <section class="links-section" aria-label="Products &amp; Resources">
      <div class="section-label">
        <span class="section-dot" aria-hidden="true"></span>
        <span>Products &amp; Resources</span>
      </div>

      <LinkCard href="#" title="Product Name" sub="Short description here">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M20 7H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"
            stroke="currentColor" stroke-width="1.8"/>
          <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"
            stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </LinkCard>
    </section>
    -->

    <!-- ===================== FOOTER ===================== -->
    <SiteFooter />

  </main>

  <script>
    (function () {
      'use strict';

      /* ---------- Staggered card entrance animation ---------- */
      function animateCards() {
        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const cards = document.querySelectorAll('.link-card');

        cards.forEach(function (card, index) {
          if (prefersReduced) {
            card.classList.add('is-visible');
            return;
          }
          var delay = 80 + index * 60;
          setTimeout(function () {
            card.classList.add('is-visible');
          }, delay);
        });
      }

      /* ---------- Promo code copy-to-clipboard ---------- */
      function copyCode(btn) {
        var code = btn.getAttribute('data-code');
        if (!code) return;

        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(code).then(function () {
            showCopied(btn);
          }).catch(function () {
            fallbackCopy(code, btn);
          });
        } else {
          fallbackCopy(code, btn);
        }
      }

      function fallbackCopy(text, btn) {
        var ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.focus();
        ta.select();
        try {
          document.execCommand('copy');
          showCopied(btn);
        } catch (e) {
          console.warn('Copy failed:', e);
        }
        document.body.removeChild(ta);
      }

      function showCopied(btn) {
        btn.classList.add('copied');
        setTimeout(function () {
          btn.classList.remove('copied');
        }, 1800);
      }

      window.copyCode = copyCode;

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', animateCards);
      } else {
        animateCards();
      }
    })();
  </script>
</BaseLayout>
