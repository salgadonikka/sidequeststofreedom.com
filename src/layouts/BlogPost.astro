---
import BaseLayout from './BaseLayout.astro';
import { Image } from 'astro:assets';
import AdUnit from '../components/AdUnit.astro';
import SiteFooter from '../components/SiteFooter.astro';
import TableOfContents from '../components/TableOfContents.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import ShareButtons from '../components/ShareButtons.astro';
import AuthorBio from '../components/AuthorBio.astro';
// import NewsletterSignup from '../components/NewsletterSignup.astro';
import ReadingProgress from '../components/ReadingProgress.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  coverImage?: ImageMetadata;
  coverAlt?: string;
  headings?: Heading[];
  readingTime?: number;
  relatedPosts?: any[];
  prevPost?: { slug: string; title: string } | null;
  nextPost?: { slug: string; title: string } | null;
  postUrl?: string;
}

const {
  title,
  description,
  pubDate,
  tags = [],
  coverImage,
  coverAlt,
  headings = [],
  readingTime = 1,
  relatedPosts = [],
  prevPost,
  nextPost,
  postUrl = '',
} = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const ogImage = coverImage
  ? `https://sidequeststofreedom.com${coverImage.src}`
  : undefined;
---

<BaseLayout title={`${title} — Side Quests To Freedom`} description={description} canonicalUrl={postUrl} ogImage={ogImage}>
  <ReadingProgress />
  <div class="bg-grid" aria-hidden="true"></div>
  <div class="bg-orb bg-orb-1" aria-hidden="true"></div>
  <div class="bg-orb bg-orb-2" aria-hidden="true"></div>

  <main class="container blog-outer">

    <!-- Main content column -->
    <div class="blog-main">
      <nav class="breadcrumb">
        <a href="/links" class="breadcrumb-link">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/blog" class="breadcrumb-link">Blog</a>
        <span aria-hidden="true">›</span>
        <span class="breadcrumb-current">{title}</span>
      </nav>

      <article data-pagefind-body>
        <header class="post-header">
          <time class="post-date" datetime={pubDate.toISOString()}>{formattedDate}</time>
          <h1 class="post-title">{title}</h1>
          <p class="post-description">{description}</p>
          <div class="post-meta-row">
            {tags.length > 0 && (
              <ul class="post-tags" aria-label="Tags">
                {tags.map((tag) => <li class="post-tag">{tag}</li>)}
              </ul>
            )}
            <span class="reading-time">{readingTime} min read</span>
          </div>
        </header>

        {coverImage && (
          <div class="cover-image-wrapper">
            <Image
              src={coverImage}
              alt={coverAlt ?? ''}
              class="cover-image"
              widths={[640, 960, 1200]}
              sizes="(max-width: 680px) 100vw, 680px"
            />
          </div>
        )}

        <!-- TOC visible inline on mobile (hidden on desktop where sidebar shows it) -->
        <div class="toc-inline">
          <TableOfContents headings={headings} />
        </div>

        <AdUnit slot="1380933491" />

        <div class="prose">
          <slot />
        </div>
      </article>

      <ShareButtons title={title} url={postUrl} />
      <AuthorBio />
      {/* <NewsletterSignup /> */}
      <RelatedPosts posts={relatedPosts} />

      <!-- Prev / Next navigation -->
      {(prevPost || nextPost) && (
        <nav class="post-nav" aria-label="Post navigation">
          <div class="post-nav-inner">
            {prevPost ? (
              <a href={`/blog/${prevPost.slug}`} class="post-nav-link post-nav-prev">
                <span class="post-nav-dir">&#8592; Previous</span>
                <span class="post-nav-title">{prevPost.title}</span>
              </a>
            ) : <div />}
            {nextPost ? (
              <a href={`/blog/${nextPost.slug}`} class="post-nav-link post-nav-next">
                <span class="post-nav-dir">Next &#8594;</span>
                <span class="post-nav-title">{nextPost.title}</span>
              </a>
            ) : <div />}
          </div>
        </nav>
      )}

      <footer class="post-footer">
        <a href="/blog" class="back-link">&#8592; All posts</a>
      </footer>

      <SiteFooter />
    </div>

    <!-- Sidebar (desktop only) -->
    <aside class="blog-sidebar">
      <div class="sidebar-sticky">
        <TableOfContents headings={headings} />
        <div class="sidebar-ad">
          <AdUnit slot="1380933491" format="rectangle" />
        </div>
      </div>
    </aside>

  </main>
</BaseLayout>

<style>
  /* ---- Outer layout ---- */
  .blog-outer {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 260px;
    gap: 3rem;
    /* stretch (default) lets sidebar match article height so sticky works */
    align-items: stretch;
    max-width: 1020px;
  }

  .blog-main {
    min-width: 0;
  }

  .blog-sidebar {
    display: block;
    position: relative;
  }

  .sidebar-sticky {
    position: sticky;
    top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    /* cap height so TOC + ad both stay visible in the viewport */
    max-height: calc(100vh - 4rem);
    overflow-y: auto;
    scrollbar-width: none;
  }

  .sidebar-sticky::-webkit-scrollbar {
    display: none;
  }

  .sidebar-ad {
    margin-top: 0.5rem;
  }

  /* Hide inline TOC on desktop (sidebar has it) */
  .toc-inline {
    display: none;
  }

  @media (max-width: 860px) {
    .blog-outer {
      grid-template-columns: 1fr;
      max-width: 680px;
    }

    .blog-sidebar {
      display: none;
    }

    /* Show inline TOC on mobile */
    .toc-inline {
      display: block;
      margin-bottom: 1.75rem;
    }
  }

  /* ---- Breadcrumb ---- */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: rgba(var(--text-rgb), 0.45);
    margin-bottom: 2.5rem;
  }

  .breadcrumb-link {
    color: rgba(var(--purple-rgb), 0.7);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb-link:hover {
    color: var(--purple);
  }

  .breadcrumb-current {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 200px;
  }

  /* ---- Post header ---- */
  .post-header {
    margin-bottom: 2rem;
    padding-bottom: 1.75rem;
    border-bottom: 1px solid rgba(var(--text-rgb), 0.07);
  }

  .post-date {
    display: block;
    font-size: 0.75rem;
    color: rgba(var(--text-rgb), 0.45);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .post-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .post-description {
    font-size: 1rem;
    color: rgba(var(--text-rgb), 0.65);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .post-meta-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
  }

  .post-tag {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--purple);
    background: rgba(var(--purple-rgb), 0.12);
    border: 1px solid rgba(var(--purple-rgb), 0.2);
    border-radius: 4px;
    padding: 0.2rem 0.5rem;
  }

  .reading-time {
    font-size: 0.72rem;
    color: rgba(var(--text-rgb), 0.4);
    white-space: nowrap;
  }

  /* ---- Cover image ---- */
  .cover-image-wrapper {
    margin-bottom: 2rem;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(var(--purple-rgb), 0.15);
  }

  .cover-image {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ---- Prose styles ---- */
  .prose {
    color: rgba(var(--text-rgb), 0.85);
    line-height: 1.75;
    font-size: 0.975rem;
  }

  .prose :global(h2) {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    margin: 2rem 0 0.75rem;
  }

  .prose :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    margin: 1.5rem 0 0.5rem;
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
  }

  .prose :global(a) {
    color: var(--purple);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }

  .prose :global(a:hover) {
    color: var(--green);
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .prose :global(li) {
    margin-bottom: 0.4rem;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--purple);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: rgba(var(--text-rgb), 0.65);
    font-style: italic;
  }

  .prose :global(code) {
    font-size: 0.85em;
    background: rgba(var(--purple-rgb), 0.12);
    border: 1px solid rgba(var(--purple-rgb), 0.2);
    border-radius: 4px;
    padding: 0.15em 0.4em;
    color: var(--green);
  }

  .prose :global(pre) {
    background: rgba(var(--purple-rgb), 0.08);
    border: 1px solid rgba(var(--purple-rgb), 0.15);
    border-radius: 8px;
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.25rem;
  }

  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.875rem;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid rgba(var(--text-rgb), 0.07);
    margin: 2rem 0;
  }

  .prose :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .prose :global(img) {
    max-width: 100%;
    border-radius: 8px;
  }

  /* ---- Prev / Next nav ---- */
  .post-nav {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(var(--text-rgb), 0.07);
  }

  .post-nav-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.85rem;
    border: 1px solid rgba(var(--purple-rgb), 0.12);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s;
  }

  .post-nav-link:hover {
    border-color: rgba(var(--purple-rgb), 0.3);
    background: rgba(var(--purple-rgb), 0.05);
  }

  .post-nav-next {
    text-align: right;
  }

  .post-nav-dir {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(var(--purple-rgb), 0.7);
  }

  .post-nav-title {
    font-size: 0.82rem;
    color: rgba(var(--text-rgb), 0.7);
    line-height: 1.35;
  }

  /* ---- Footer ---- */
  .post-footer {
    margin-top: 2.5rem;
    padding-top: 1.75rem;
    border-top: 1px solid rgba(var(--text-rgb), 0.07);
  }

  .back-link {
    font-size: 0.85rem;
    color: rgba(var(--purple-rgb), 0.7);
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--purple);
  }

  @media (max-width: 480px) {
    .post-title {
      font-size: 1.5rem;
    }

    .post-nav-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
